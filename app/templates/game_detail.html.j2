<!DOCTYPE html>
<html>
<head>
    <title>Game {{ game.id }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .prompt { background: #f8f9fa; border-left: 4px solid #0d6efd; padding: 10px; font-family: monospace; white-space: pre-wrap; }
        .response { background: #e9ecef; border-left: 4px solid #198754; padding: 10px; margin-top: 5px; white-space: pre-wrap; }
        .metadata { font-size: 0.8em; color: #6c757d; }
        .bb-log { background: #1e1e1e; color: #4af626; font-family: monospace; padding: 15px; border-radius: 5px; margin-bottom: 10px; white-space: pre-wrap; border-left: 4px solid #4af626;}
    </style>
</head>
<body class="container mt-4 mb-5">
    <a href="/dashboard" class="btn btn-outline-secondary mb-3">&larr; Back to Dashboard</a>
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Game: {{ game.id }}</h1>
            <p class="text-muted mb-0">Status: {{ game.status }} | Host: {{ game.host_id }} | Cycle: {{ game.metadata.cycle | default(1) }}</p>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs mb-4" id="gameTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold text-success" id="blackbox-tab" data-bs-toggle="tab" data-bs-target="#blackbox" type="button" role="tab">Black Box Logs</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="state-tab" data-bs-toggle="tab" data-bs-target="#state" type="button" role="tab">State Metadata</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="wire-tab" data-bs-toggle="tab" data-bs-target="#wire" type="button" role="tab">AI Wire Logs</button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content" id="gameTabsContent">
        
        <!-- Black Box Logs Tab -->
        <div class="tab-pane fade show active" id="blackbox" role="tabpanel">
            {% if game.metadata.blackbox_logs %}
                {% for log in game.metadata.blackbox_logs %}
                    <div class="bb-log">{{ log }}</div>
                {% endfor %}
            {% else %}
                <div class="alert alert-dark text-center">
                    No black box telemetry recorded yet.
                </div>
            {% endif %}
        </div>

        <!-- State Metadata Tab -->
        <div class="tab-pane fade" id="state" role="tabpanel">
            <pre class="bg-light p-3 border rounded" style="font-size: 0.9em;">{{ game.metadata | tojson(indent=2) }}</pre>
        </div>

        <!-- AI Wire Logs Tab -->
        <div class="tab-pane fade" id="wire" role="tabpanel">
            {% if logs %}
                {% for log in logs %}
                <div class="card mb-3">
                    <div class="card-header">
                        <span class="badge bg-secondary">{{ log.model }}</span>
                        <span class="float-end metadata">{{ log.timestamp }} | Tokens: {{ log.usage.total_tokens }}</span>
                    </div>
                    <div class="card-body">
                        <strong>User Input:</strong>
                        <div class="prompt">{{ log.user_input }}</div>
                        <strong>AI Response:</strong>
                        <div class="response">{{ log.raw_response }}</div>
                        <details class="mt-3">
                            <summary class="text-muted" style="cursor: pointer;">View System Prompt</summary>
                            <pre class="small mt-2 bg-light p-2 border rounded">{{ log.system_prompt }}</pre>
                        </details>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <div class="alert alert-secondary text-center">
                    No AI interactions recorded yet.
                </div>
            {% endif %}
        </div>
        
    </div>

    <!-- Bootstrap JS Bundle (includes Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>